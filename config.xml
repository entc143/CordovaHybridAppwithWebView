<?xml version='1.0' encoding='utf-8'?>
<widget id="com.clevertap.cordovahybridappwithwebview"
        version="1.0.0"
        xmlns="http://www.w3.org/ns/widgets"
        xmlns:gap="http://phonegap.com/ns/1.0"
        xmlns:android="http://schemas.android.com/apk/res/android">

    <name>CordovaHybridAppwithWebView</name>

    <description>
        A hybrid Cordova sample app demonstrating a live auto-incrementing counter,
        a WebView "Thank You" page, and full CleverTap integration: Push Notifications
        (with foreground / background / killed impression tracking), In-App messages,
        and App Native Display banners.
    </description>

    <author email="sachin.gajbhiye@clevertap.com" href="https://clevertap.com">
        CleverTap Onboarding
    </author>

    <!-- App entry point -->
    <content src="index.html" />

    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />

    <!-- ============================================================= -->
    <!--  CleverTap Cordova plugin                                     -->
    <!--  Ref: https://developer.clevertap.com/docs/cordova-quick-start-guide -->
    <!-- ============================================================= -->
    <gap:plugin name="clevertap-cordova" source="npm">
        <param name="CLEVERTAP_ACCOUNT_ID" value="R57-R8W-557Z" />
        <param name="CLEVERTAP_TOKEN" value="0b2-a52" />
    </gap:plugin>

    <!-- Required so the CleverTap Cordova plugin is installed with credentials.
         Install command (note the double-dash before "variable"):
           cordova plugin add https://github.com/CleverTap/clevertap-cordova.git
           [dash][dash]variable CLEVERTAP_ACCOUNT_ID="R57-R8W-557Z"
           [dash][dash]variable CLEVERTAP_TOKEN="0b2-a52"
         See README.md "Run Instructions" for the exact command. -->

    <!-- Build preferences -->
    <preference name="android-build-tool" value="gradle" />
    <preference name="AndroidXEnabled" value="true" />
    <preference name="android-minSdkVersion" value="21" />
    <preference name="android-targetSdkVersion" value="34" />
    <preference name="Orientation" value="portrait" />
    <preference name="DisallowOverscroll" value="true" />

    <!-- ============================================================= -->
    <!--  ANDROID                                                      -->
    <!-- ============================================================= -->
    <platform name="android">
        <!-- CleverTap Account credentials injected as manifest meta-data.
             config-file edits are applied into AndroidManifest.xml on `cordova prepare`. -->
        <config-file target="AndroidManifest.xml" parent="/manifest/application">
            <meta-data android:name="CLEVERTAP_ACCOUNT_ID" android:value="R57-R8W-557Z" />
            <meta-data android:name="CLEVERTAP_TOKEN" android:value="0b2-a52" />
            <!-- 0=None, 1=Medium encryption for PII (Cordova SDK v2.7.1+) -->
            <meta-data android:name="CLEVERTAP_ENCRYPTION_LEVEL" android:value="1" />
        </config-file>

        <!-- Use CleverTap's Application class so notification opens, in-apps,
             deep links and lifecycle events are captured. THIS IS MANDATORY. -->
        <edit-config file="AndroidManifest.xml"
                     target="/manifest/application"
                     mode="merge"
                     xmlns:android="http://schemas.android.com/apk/res/android">
            <application android:name="com.clevertap.android.sdk.Application" />
        </edit-config>

        <!-- FCM push message listener service for CleverTap default push handling -->
        <config-file target="AndroidManifest.xml" parent="/manifest/application">
            <service android:name="com.clevertap.android.sdk.pushnotification.fcm.FcmMessageListenerService"
                     android:exported="false">
                <intent-filter>
                    <action android:name="com.google.firebase.MESSAGING_EVENT" />
                </intent-filter>
            </service>
        </config-file>

        <!-- Permissions -->
        <config-file target="AndroidManifest.xml" parent="/manifest">
            <uses-permission android:name="android.permission.INTERNET" />
            <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
            <uses-permission android:name="android.permission.WAKE_LOCK" />
            <!-- Required from Android 13 (API 33) to post notifications -->
            <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
        </config-file>

        <!-- FCM push: after you add a Firebase project, drop google-services.json
             next to this config.xml and UNCOMMENT the line below so Cordova copies
             it into the Android build. Left commented so the app builds without Firebase. -->
        <!-- <resource-file src="google-services.json" target="app/google-services.json" /> -->
    </platform>

    <!-- ============================================================= -->
    <!--  iOS                                                          -->
    <!-- ============================================================= -->
    <platform name="ios">
        <!-- CleverTap Account credentials in Info.plist -->
        <config-file target="*-Info.plist" parent="CleverTapAccountID">
            <string>R57-R8W-557Z</string>
        </config-file>
        <config-file target="*-Info.plist" parent="CleverTapToken">
            <string>0b2-a52</string>
        </config-file>
        <!-- 0=None, 1=Medium encryption for PII -->
        <config-file target="*-Info.plist" parent="CleverTapEncryptionLevel">
            <string>1</string>
        </config-file>

        <preference name="deployment-target" value="12.0" />
    </platform>

    <!-- Recommended core plugins -->
    <plugin name="cordova-plugin-inappbrowser" spec="^6.0.0" />
    <engine name="android" spec="^12.0.0" />
    <engine name="ios" spec="^7.0.0" />
</widget>
